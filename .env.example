# ── Supabase ──────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Twilio (set these as Supabase Secrets, NOT here) ──
# These go in your Supabase Edge Function secrets, NOT in this .env file.
# Run: supabase secrets set TWILIO_ACCOUNT_SID=ACxxx
# Run: supabase secrets set TWILIO_AUTH_TOKEN=xxx
# Run: supabase secrets set TWILIO_FROM_NUMBER=+1xxxxxxxxxx
